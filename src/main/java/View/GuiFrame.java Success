    private void jButton1ActionPerformed(java.awt.event.ActionEvent evt) {//GEN-FIRST:event_jButton1ActionPerformed
        // TODO add your handling code here:
        // First get the user name and password
        String UserName = jTextField1.getText(); //this is for the username
        String Password = jTextField2.getText(); // This is for the password
        
        //This section is for the code, the code bellow is for the Validation
        
         if (UserName.equals("") && Password.equals(""))// If both user name and password are both empty, then the following
             //message will be displayed
            JOptionPane.showMessageDialog(this, "please enter Username and password");
        
    //Case 2: This section is for if the user is entered and the password is blank
         else if (!UserName.equals("") && Password.equals("")) 
            JOptionPane.showMessageDialog(this, "please enter password.......");
        
                
    //Case 3: This section is for if the Username us null and the Password is entered
         else if (UserName.equals("") && !(Password.equals("")))
             JOptionPane.showMessageDialog(this, "please enter UserName.......");
        
    //Case 4: What must happen is the user enters all the parts of the form
         else if (UserName.equals("Darlington") && (Password.equals("12345")))
             JOptionPane.showMessageDialog(this, "Congratulations you have successfully logged in!!!");
         
         else
        JOptionPane.showMessageDialog(this, "Incorrect Username or Password!!!");
            
      
    }//GEN-LAST:event_jButton1ActionPerformed

